<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= chapter.title %> · <%= siteName %></title>
  <meta name="description" content="اقرأ الفصل <%= chapter.chapter_number %>: <%= chapter.title %><%= chapter.novels ? ' من رواية ' + chapter.novels.title : '' %> على <%= siteName %>">
  <meta name="robots" content="index, follow">
  <link rel="canonical" href="<%= siteUrl %>/read/<%= chapter.novels ? chapter.novels.id : '' %>/<%= chapter.id %>">
  <link rel="icon" type="image/png" href="/logo.png">
  <meta property="og:type" content="article">
  <meta property="og:site_name" content="Echo Memories · صدى الذكريات">
  <meta property="og:title" content="<%= chapter.title %> · <%= siteName %>">
  <meta property="og:url" content="<%= siteUrl %>/read/<%= chapter.novels ? chapter.novels.id : '' %>/<%= chapter.id %>">
  <link rel="stylesheet" href="/style.css?v=<%= assetVersion %>">
</head>
<body>
  <%- include('header') %>

  <main class="reading">
    <div class="chapter-container">
      <h1><%= chapter.title %></h1>
      <p class="chapter-breadcrumb">
        الفصل <%= chapter.chapter_number %>
        <% if (chapter.novels) { %> · <a href="/novel/<%= chapter.novels.id %>"><%= chapter.novels.title %></a><% } %>
      </p>

      <div class="chapter-meta-row">
        <% if (chapter.novels && chapter.novels.status) { %><span class="mini-pill status-pill"><%= chapter.novels.status %></span><% } %>
        <% if (chapter.novels && chapter.novels.genre) { %><span class="mini-pill"><%= chapter.novels.genre %></span><% } %>
        <% if (chapter.novels && chapter.novels.world) { %><span class="mini-pill"><%= chapter.novels.world %></span><% } %>
      </div>

      <div class="chapter-content" id="chapterContent"><%- safeContent %></div>

      <div class="font-control">
        <label for="fontSlider">حجم الخط</label>
        <input type="range" id="fontSlider" min="13" max="32" value="18" step="1">
        <span class="font-size-display" id="fontDisplay">18</span>
      </div>

      <div class="chapter-nav">
        <% if (prevChapter) { %>
          <a href="/read/<%= chapter.novels ? chapter.novels.id : '' %>/<%= prevChapter.id %>" class="nav-btn">← الفصل السابق</a>
        <% } else { %>
          <span class="nav-btn disabled">← السابق</span>
        <% } %>
        <% if (chapter.novels) { %>
          <a href="/novel/<%= chapter.novels.id %>" class="nav-btn nav-center">📖 قائمة الفصول</a>
        <% } %>
        <% if (nextChapter) { %>
          <a href="/read/<%= chapter.novels ? chapter.novels.id : '' %>/<%= nextChapter.id %>" class="nav-btn">الفصل التالي →</a>
        <% } else { %>
          <span class="nav-btn disabled">التالي →</span>
        <% } %>
      </div>
    </div>

    <section class="comments-section" id="comments" style="max-width:780px;margin:0 auto;">
      <div class="section-head">
        <h2 class="section-title">💬 التعليقات</h2>
        <span class="section-count"><%= comments.length %> تعليق</span>
      </div>
      <% if (user) { %>
        <div class="comment-form">
          <form action="/comment" method="POST" data-comment-form data-comment-target="chapter" data-comment-target-id="<%= chapter.id %>">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <input type="hidden" name="target_type" value="chapter">
            <input type="hidden" name="target_id" value="<%= chapter.id %>">
            <input type="hidden" name="return_to" value="<%= currentPath %>">
            <textarea name="content" placeholder="اكتب شي… حتى لو كلمة 💬" maxlength="2000"></textarea>
            <button type="submit" class="submit-btn">إرسال 📨</button>
          </form>
        </div>
      <% } else { %>
        <p class="muted-text">سجّل دخولك عشان تشاركنا رأيك.</p>
      <% } %>
      <div class="old-comments comments-list" data-comment-list>
        <% if (comments && comments.length) { %>
          <% comments.forEach((c, i) => { %>
            <div class="one-comment" style="animation-delay:<%= i * 0.07 %>s">
              <div class="comment-avatar">
                <% if (c.users && c.users.avatar) { %>
                  <img src="<%= c.users.avatar %>" onerror="this.src='/logo.png'" alt="">
                <% } else { %>👤<% } %>
              </div>
              <div class="comment-body">
                <strong><%= c.users ? c.users.username : 'مجهول' %></strong>
                <span class="comment-date"><%= new Date(c.created_at).toLocaleString('ar') %></span>
                <p><%= c.content %></p>
                <% if (user && (user.role === 'مطور' || user.role === 'مشرف' || user.role === 'مؤلف_أسطوري')) { %>
                  <div class="comment-actions">
                    <form action="/comment/delete/<%= c.id %>" method="POST" style="display:inline">
                      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                      <button type="submit" class="delete-comment">🗑️ حذف</button>
                    </form>
                  </div>
                <% } %>
              </div>
            </div>
          <% }); %>
        <% } else { %>
          <p class="muted-text" data-empty-comments>ولا تعليق… كن أول من يكتب ✍️</p>
        <% } %>
      </div>
    </section>
  </main>

  <footer>
    <p>موقع تابع لسيرفر <a href="<%= discordServerUrl %>" target="_blank" rel="noopener">صدى الذكريات</a></p>
    <p>صنع بـ <span class="footer-heart">♥</span> من قبل <span style="background:linear-gradient(135deg,#c084fc,#e879f9);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;font-weight:700">Dark</span></p>
  </footer>

  <button class="back-top" id="backTop" aria-label="العودة لأعلى">↑</button>
  <script src="/script.js?v=<%= assetVersion %>"></script>
</body>
</html>
