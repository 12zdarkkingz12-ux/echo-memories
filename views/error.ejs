<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= code %> · خطأ · Echo Memories</title>
  <meta name="robots" content="noindex">
  <link rel="stylesheet" href="/style.css?v=<%= assetVersion %>">
  <link rel="icon" type="image/png" href="/logo.png">
</head>
<body>
  <%- include('header') %>
  <main>
    <div class="error-page">
      <div class="error-code"><%= code %></div>
      <h2 class="error-title">
        <% if (code == 403) { %>ما عندك صلاحية 🔒
        <% } else if (code == 401) { %>سجّل دخولك أولاً 👤
        <% } else if (code == 400) { %>طلب غير صحيح ⚠️
        <% } else { %>صار خطأ في الخادم 🛠️
        <% } %>
      </h2>
      <p class="error-msg"><%= message %></p>
      <div class="error-actions">
        <a href="/" class="nav-btn nav-center">🏠 الرئيسية</a>
        <a href="javascript:history.back()" class="nav-btn">← ارجع للخلف</a>
      </div>
    </div>
  </main>

  <footer>
    <p>موقع تابع لسيرفر <a href="<%= discordServerUrl %>" target="_blank" rel="noopener">صدى الذكريات</a></p>
    <p>صنع <span style="color:var(--primary)">Dark</span></p>
  </footer>
  <script src="/script.js?v=<%= assetVersion %>"></script>
</body>
</html>
