<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <title>لوحتي · Echo Memories</title>
    <link rel="stylesheet" href="/style.css?v=<%= assetVersion %>">
</head>
<body>
    <header>
        <div class="logo">📖 Echo Memories</div>
        <nav>
            <span><%= user.username %> [<%= user.role %>]</span>
            <a href="/">الرئيسية</a>
            <a href="/logout">خروج</a>
            <button id="theme-switch">🌙/☀️</button>
        </nav>
    </header>
    <main>
        <h1>لوحة التحكم</h1>
        <h3>رواياتي</h3>
        <% if (novels && novels.length) { %>
            <ul>
                <% novels.forEach(n => { %>
                    <li><a href="/novel/<%= n.id %>"><%= n.title %></a></li>
                <% }); %>
            </ul>
        <% } else { %>
            <p>ما عندك روايات بعد.</p>
        <% } %>

        <hr style="margin: 2rem 0; border-color: var(--gold-dim);">
        <h3>إضافة فصل جديد</h3>
        <form action="/chapter/new" method="POST" class="form-card">
            <%# ✅ CSRF Token %>
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <input type="number" name="novel_id" placeholder="معرف الرواية" required min="1">
            <input type="number" name="chapter_number" placeholder="رقم الفصل" required min="1">
            <input type="text" name="title" placeholder="عنوان الفصل" required maxlength="200">
            <textarea name="content" placeholder="اكتب الفصل هنا..." rows="10" required></textarea>
            <button type="submit">نشر الفصل</button>
        </form>
    </main>
    <footer>
        <p>موقع تابع لسيرفر <a href="<%= discordServerUrl %>" target="_blank" rel="noopener" class="gold">صدى الذكريات</a></p>
        <p>صنع <span class="gold">Dark</span></p>
    </footer>
    <script src="/script.js?v=<%= assetVersion %>"></script>
</body>
</html>
