<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>لوحتي · Echo Memories</title>
  <link rel="stylesheet" href="/style.css?v=<%= assetVersion %>">
  <link rel="icon" type="image/png" href="/logo.png">
</head>
<body>
  <%- include('header') %>
  <main>
    <h1>📋 لوحتي</h1>

    <section style="margin-bottom:2.5rem;">
      <h2 class="section-title">📚 رواياتي</h2>
      <% if (novels && novels.length) { %>
        <div class="novels-list">
          <% novels.forEach(n => { %>
            <div class="novel-list-item">
              <span>📖</span>
              <a href="/novel/<%= n.id %>"><%= n.title %></a>
            </div>
          <% }); %>
        </div>
      <% } else { %>
        <div class="empty-state" style="padding:2rem 0;">
          <span class="empty-icon">🌸</span>
          <p>ما عندك روايات بعد — ابدأ الكتابة!</p>
        </div>
      <% } %>
    </section>

    <section>
      <h2 class="section-title">✍️ إضافة فصل جديد</h2>
      <form action="/chapter/new" method="POST" class="form-card">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <input type="number" name="novel_id" placeholder="معرف الرواية" required min="1">
        <input type="number" name="chapter_number" placeholder="رقم الفصل" required min="1">
        <input type="text" name="title" placeholder="عنوان الفصل" required maxlength="200">
        <textarea name="content" placeholder="اكتب الفصل هنا…" rows="12" required></textarea>
        <button type="submit" class="submit-btn">نشر الفصل 🚀</button>
      </form>
    </section>
  </main>

  <footer>
    <p>موقع تابع لسيرفر <a href="<%= discordServerUrl %>" target="_blank" rel="noopener">صدى الذكريات</a></p>
    <p>صنع <span style="color:var(--primary)">Dark</span></p>
  </footer>

  <button class="back-top" id="backTop" aria-label="العودة لأعلى">↑</button>
  <script src="/script.js?v=<%= assetVersion %>"></script>
</body>
</html>
