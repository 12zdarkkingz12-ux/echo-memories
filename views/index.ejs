<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= siteName %> · صدى الذكريات</title>
  <meta name="description" content="منصة نشر روايات عربية أصلية. اقرأ، علّق، وابحث بالتصنيفات.">
  <meta name="robots" content="index, follow">
  <link rel="canonical" href="<%= siteUrl %>/">
  <link rel="icon" type="image/png" href="/logo.png">
  <meta property="og:type" content="website">
  <meta property="og:site_name" content="Echo Memories · صدى الذكريات">
  <meta property="og:title" content="<%= siteName %> · صدى الذكريات">
  <meta property="og:description" content="منصة نشر روايات عربية أصلية. اقرأ، علّق، وابحث بالتصنيفات.">
  <meta property="og:url" content="<%= siteUrl %>/">
  <meta property="og:locale" content="ar_SA">
  <meta property="og:image" content="<%= siteUrl %>/logo.png">
  <meta name="twitter:card" content="summary">
  <meta name="twitter:title" content="<%= siteName %> · صدى الذكريات">
  <meta name="twitter:description" content="منصة نشر روايات عربية أصلية. اقرأ، علّق، وابحث بالتصنيفات.">
  <link rel="stylesheet" href="/style.css?v=<%= assetVersion %>">
</head>
<body>
  <%- include('header') %>

  <main>
    <section class="hero" id="hero">
      <div class="hero-ring"></div>
      <div class="hero-ring r2"></div>
      <p class="hero-eyebrow">✦ منصة الروايات العربية</p>
      <h1 class="hero-title">صدى الذكريات</h1>
      <p class="hero-sub">مكان تجتمع فيه الروايات والقرّاء — ابحث، اقرأ، وعلّق على مزاجك.</p>
      <a href="#novels" class="hero-cta">✨ ابدأ الاستكشاف</a>
    </section>

    <section class="search-panel" aria-label="البحث والتصنيفات">
      <form method="GET" action="/" class="filter-form">
        <div class="filter-row">
          <div class="search-wrapper" style="width:100%">
            <span class="search-icon">🔍</span>
            <input type="text" name="q" value="<%= filters.q %>" placeholder="ابحث عن رواية أو مؤلف أو وسم..." class="filter-input">
          </div>
        </div>

        <div class="filter-grid">
          <label>
            <span>التصنيف الأساسي</span>
            <select name="genre">
              <option value="الكل" <%= filters.genre === 'الكل' ? 'selected' : '' %>>الكل</option>
              <% categoryGroups.basic.forEach(item => { %>
                <option value="<%= item %>" <%= filters.genre === item ? 'selected' : '' %>><%= item %></option>
              <% }) %>
            </select>
          </label>

          <label>
            <span>العالم / النظام</span>
            <select name="world">
              <option value="الكل" <%= filters.world === 'الكل' ? 'selected' : '' %>>الكل</option>
              <% categoryGroups.worlds.forEach(item => { %>
                <option value="<%= item %>" <%= filters.world === item ? 'selected' : '' %>><%= item %></option>
              <% }) %>
            </select>
          </label>

          <label>
            <span>وسم مشهور</span>
            <select name="tag">
              <option value="الكل" <%= filters.tag === 'الكل' ? 'selected' : '' %>>الكل</option>
              <% categoryGroups.popularTags.forEach(item => { %>
                <option value="<%= item %>" <%= filters.tag === item ? 'selected' : '' %>><%= item %></option>
              <% }) %>
            </select>
          </label>

          <label>
            <span>حالة الرواية</span>
            <select name="status">
              <option value="الكل" <%= filters.status === 'الكل' ? 'selected' : '' %>>الكل</option>
              <% categoryGroups.status.forEach(item => { %>
                <option value="<%= item %>" <%= filters.status === item ? 'selected' : '' %>><%= item %></option>
              <% }) %>
            </select>
          </label>
        </div>

        <div class="filter-actions">
          <button type="submit" class="submit-btn">بحث</button>
          <a href="/" class="ghost-btn">إعادة ضبط</a>
        </div>
      </form>
    </section>

    <section id="novels">
      <div class="section-head">
        <h2 class="section-title">📚 أحدث الروايات</h2>
        <span class="section-count"><%= allNovelsCount %> رواية</span>
      </div>

      <div class="novels-grid">
        <% if (novels && novels.length) { %>
          <% novels.forEach((novel, i) => { %>
            <a href="/novel/<%= novel.id %>" class="novel-card"
               style="background-image:url('<%= novel.cover_image || defaultCover %>');animation-delay:<%= i * 0.08 %>s">
              <div class="card-shine"></div>
              <div class="card-body">
                <div class="card-tags">
                  <% if (novel.status) { %><span class="mini-pill status-pill"><%= novel.status %></span><% } %>
                  <% if (novel.genre) { %><span class="mini-pill"><%= novel.genre %></span><% } %>
                </div>
                <h2><%= novel.title %></h2>
                <p class="author">✍️ <%= novel.author_display %></p>
                <p class="meta-line">📖 <%= novel.chapter_count %> فصول</p>
                <% if (novel.world) { %><p class="meta-line">✨ <%= novel.world %></p><% } %>
              </div>
            </a>
          <% }); %>
        <% } else { %>
          <div class="empty-state">
            <span class="empty-icon">🌸</span>
            <p>ما لقينا نتائج هنا — جرّب تصنيف مختلف.</p>
          </div>
        <% } %>
      </div>
    </section>
  </main>

  <footer>
    <p>موقع تابع لسيرفر <a href="<%= discordServerUrl %>" target="_blank" rel="noopener">صدى الذكريات</a></p>
    <p>صنع بـ <span class="footer-heart">♥</span> من قبل <span style="background:linear-gradient(135deg,#c084fc,#e879f9);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;font-weight:700">Dark</span></p>
  </footer>

  <button class="back-top" id="backTop" aria-label="العودة لأعلى">↑</button>
  <script src="/script.js?v=<%= assetVersion %>"></script>
</body>
</html>
