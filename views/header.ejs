<canvas id="starCanvas" aria-hidden="true"></canvas>

<!-- ===== Sidebar Overlay ===== -->
<div class="sidebar-overlay" id="sidebarOverlay"></div>

<!-- ===== Sidebar ===== -->
<aside class="sidebar" id="sidebar" role="navigation" aria-label="القائمة الجانبية">
  <div class="sidebar-header">
    <button class="sidebar-close" id="sidebarClose" aria-label="إغلاق القائمة">✕</button>
  </div>

  <div class="sidebar-user">
    <% if (user) { %>
      <img class="sidebar-avatar" src="<%= user.avatar || '/logo.png' %>" alt="<%= user.username %>" onerror="this.src='/logo.png'" />
      <span class="sidebar-username"><%= user.username %></span>
      <span class="sidebar-role"><%= user.role %></span>
    <% } else { %>
      <img class="sidebar-avatar" src="/logo.png" alt="<%= siteName %>" />
      <span class="sidebar-username">زائر</span>
      <span class="sidebar-role">غير مسجّل</span>
    <% } %>
  </div>

  <nav class="sidebar-nav">
    <a href="/"><span class="nav-icon">🏠</span> الرئيسية</a>
    <% if (user && ['مؤلف','مؤلف_أسطوري','مشرف','مطور'].includes(user.role)) { %>
    <a href="/dashboard"><span class="nav-icon">📋</span> لوحتي</a>
    <% } %>
  </nav>

  <% if (user) { %>
  <a href="/logout" class="discord-btn" style="background:#5865F2;margin-bottom:0.5rem;">
    <svg width="18" height="18" viewBox="0 0 127.14 96.36" fill="currentColor" xmlns="http://www.w3.org/2000/svg"><path d="M107.7 8.07A105.15 105.15 0 0 0 81.47 0a72.06 72.06 0 0 0-3.36 6.83 97.68 97.68 0 0 0-29.11 0A72.37 72.37 0 0 0 45.64 0a105.89 105.89 0 0 0-26.25 8.09C2.79 32.65-1.71 56.6.54 80.21a105.73 105.73 0 0 0 32.17 16.15 77.7 77.7 0 0 0 6.89-11.11 68.42 68.42 0 0 1-10.85-5.18c.91-.66 1.8-1.34 2.66-2a75.57 75.57 0 0 0 64.32 0c.87.71 1.76 1.39 2.66 2a68.68 68.68 0 0 1-10.87 5.19 77 77 0 0 0 6.89 11.1 105.25 105.25 0 0 0 32.19-16.14c2.64-27.38-4.51-51.11-18.9-72.15zM42.45 65.69C36.18 65.69 31 60 31 53s5-12.74 11.43-12.74S54 46 53.89 53s-5.05 12.69-11.44 12.69zm42.24 0C78.41 65.69 73.25 60 73.25 53s5-12.74 11.44-12.74S96.23 46 96.12 53s-5.04 12.69-11.43 12.69z"/></svg>
    خروج
  </a>
  <% } else { %>
  <a href="/auth/discord" class="discord-btn">
    <svg width="18" height="18" viewBox="0 0 127.14 96.36" fill="currentColor" xmlns="http://www.w3.org/2000/svg"><path d="M107.7 8.07A105.15 105.15 0 0 0 81.47 0a72.06 72.06 0 0 0-3.36 6.83 97.68 97.68 0 0 0-29.11 0A72.37 72.37 0 0 0 45.64 0a105.89 105.89 0 0 0-26.25 8.09C2.79 32.65-1.71 56.6.54 80.21a105.73 105.73 0 0 0 32.17 16.15 77.7 77.7 0 0 0 6.89-11.11 68.42 68.42 0 0 1-10.85-5.18c.91-.66 1.8-1.34 2.66-2a75.57 75.57 0 0 0 64.32 0c.87.71 1.76 1.39 2.66 2a68.68 68.68 0 0 1-10.87 5.19 77 77 0 0 0 6.89 11.1 105.25 105.25 0 0 0 32.19-16.14c2.64-27.38-4.51-51.11-18.9-72.15zM42.45 65.69C36.18 65.69 31 60 31 53s5-12.74 11.43-12.74S54 46 53.89 53s-5.05 12.69-11.44 12.69zm42.24 0C78.41 65.69 73.25 60 73.25 53s5-12.74 11.44-12.74S96.23 46 96.12 53s-5.04 12.69-11.43 12.69z"/></svg>
    دخول بديسكورد
  </a>
  <% } %>

  <div class="sidebar-footer">
    <span>Echo Memories © 2025</span>
    <button class="theme-btn" id="theme-switch" aria-label="تبديل الثيم">🌙</button>
  </div>
</aside>

<!-- ===== Header ===== -->
<header>
  <a href="/" class="logo" aria-label="الرئيسية">
    <img src="/logo.png" alt="Echo Memories" loading="eager">
    <span class="logo-text">Echo Memories</span>
  </a>
  <div class="header-actions">
    <button class="menu-btn" id="menuBtn" aria-label="فتح القائمة" aria-expanded="false">☰</button>
  </div>
</header>
