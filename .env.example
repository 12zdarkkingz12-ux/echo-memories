# Supabase
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key

# Discord OAuth
DISCORD_CLIENT_ID=your_client_id
DISCORD_CLIENT_SECRET=your_client_secret
DISCORD_REDIRECT_URI=https://your-domain.onrender.com/auth/discord/callback

# Session — اعمل string عشوائي طويل (مثلاً من: https://randomkeygen.com)
SESSION_SECRET=replace_with_a_long_random_string

# البيئة — production في Render، development محلياً
NODE_ENV=production

# رابط الموقع — يُستخدم في OG tags والـ canonical URL
SITE_URL=https://your-domain.onrender.com

# رابط سيرفر ديسكورد — يُستخدم في الفوتر وأي مكان ثاني
DISCORD_SERVER_URL=https://discord.gg/xxxxxxx

# إصدار الملفات الثابتة — غيّره عند أي تحديث CSS أو JS لتجنب مشاكل الكاش
ASSET_VERSION=1
